# Supabase project connection. The publishable key is safe to expose to the
# browser by design (it only works within whatever RLS policies allow) -
# it is NOT a secret. Never put a secret/service_role key in this project;
# the site never needs one for reading the public product catalog.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
