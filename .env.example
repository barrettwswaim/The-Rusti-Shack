# Supabase project connection. The publishable key is safe to expose to the
# browser by design (it only works within whatever RLS policies allow) -
# it is NOT a secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase SECRET key. Server-only - never prefix with NEXT_PUBLIC_, never
# use in any file that runs in the browser. This is the only key that can
# write to Customers_Core, Customers_Contact, Orders, and OrderLines
# (those tables have zero public policies by design). Used only by
# lib/supabaseAdmin.js, imported only by the two Stripe API routes.
SUPABASE_SECRET_KEY=

# Stripe test-mode keys. Both server-only.
# Secret key (sk_test_...): used to create Checkout Sessions and verify
# webhook signatures. Never prefix with NEXT_PUBLIC_, never commit it.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...): issued per webhook endpoint in the
# Stripe dashboard (or by the Stripe CLI for local testing). Required to
# verify that a webhook request actually came from Stripe before trusting
# it - see app/api/stripe-webhook/route.js.
STRIPE_WEBHOOK_SECRET=

# Shared password for the private /manager sales page. Server-only -
# never prefix with NEXT_PUBLIC_, never put it in any client file.
# Treat it like a real account password (long, unique, not reused from
# anywhere else) - it also doubles as the signing key for the manager
# session cookie, so changing it instantly signs everyone out.
MANAGER_PASSWORD=

# Shared password for the private /management back office (Part C).
# Server-only, same rules as MANAGER_PASSWORD above - never commit a
# real value here, never prefix with NEXT_PUBLIC_. Deliberately a
# separate secret from MANAGER_PASSWORD (different page, different
# session cookie) so rotating one never signs the other out.
MANAGEMENT_PASSWORD=
